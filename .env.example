# Enable Banking – Account Information API (kostenlos für Privatnutzer)
# Anwendung registrieren unter: https://enablebanking.com/ -> "Applications".
# Beim Registrieren lädt dein Browser einen privaten Schlüssel (.pem) herunter;
# der Dateiname ist die App-ID, z. B. aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee.pem
ENABLEBANKING_APP_ID=deine-app-id-hier
ENABLEBANKING_KEY_PATH=./enablebanking_private_key.pem

# Redirect-URL: MUSS exakt einer in der App-Registrierung hinterlegten URL
# entsprechen. Nach dem Bank-Login landest du hier mit ?code=... in der Adresszeile.
ENABLEBANKING_REDIRECT_URL=https://dankeyking.github.io/privatefinance/

# Basis-URL der API (normalerweise nicht ändern)
ENABLEBANKING_BASE_URL=https://api.enablebanking.com

# Mock-Modus: true = App nutzt immer Mock-Daten (kein API-Aufruf nötig).
# Das Fetch-Skript (scripts/fetch-data.js) ignoriert diese Variable und holt
# bei Aufruf immer echte Daten – die App selbst lädt public/data.json, sobald
# diese Datei existiert.
VITE_MOCK_MODE=false
