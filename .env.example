# GoCardless / Nordigen Bank Account Data API
# Anlegen unter: https://bankaccountdata.gocardless.com/ -> User Secrets
GOCARDLESS_SECRET_ID=dein-secret-id-hier
GOCARDLESS_SECRET_KEY=dein-secret-key-hier

# Mock-Modus: true = App nutzt immer Mock-Daten (kein API-Aufruf nötig).
# Das Fetch-Skript (scripts/fetch-data.js) ignoriert diese Variable und holt
# bei Aufruf immer echte Daten – die App selbst lädt public/data.json, sobald
# diese Datei existiert.
MOCK_MODE=true

# Basis-URL der API (normalerweise nicht ändern)
GOCARDLESS_BASE_URL=https://bankaccountdata.gocardless.com/api/v2
