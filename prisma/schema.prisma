generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id       String @id
  groupId  String @default("familie")
  name     String
  owner    String
  type     String
  balance  Float
  color    String
  goal     Float?
  currency String

  @@index([groupId])
}

model Income {
  id           String @id
  groupId      String @default("familie")
  name         String
  amount       Float
  rhythm       String
  accountId    String
  executionDay Int

  @@index([groupId])
}

model StandingOrder {
  id            String  @id
  groupId       String  @default("familie")
  recipient     String
  amount        Float
  rhythm        String
  accountId     String
  category      String
  kind          String
  executionDay  Int
  dueMonth      Int?
  endDate       String?
  split         Json
  monthInterval Int
  nextExecution String

  @@index([groupId])
}

model Transfer {
  id            String @id
  groupId       String @default("familie")
  label         String
  amount        Float
  fromAccountId String
  toAccountId   String
  rhythm        String

  @@index([groupId])
}

model CategoryOverride {
  itemId     String @id
  groupId    String @default("familie")
  categoryId String

  @@index([groupId])
}

model Debt {
  id              String  @id
  groupId         String  @default("familie")
  name            String
  creditor        String
  totalAmount     Float
  remainingAmount Float
  rate            Float
  rhythm          String
  accountId       String?

  @@index([groupId])
}
